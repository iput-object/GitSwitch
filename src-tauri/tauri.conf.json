{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gitswitch",
  "version": "1.1.0",
  "identifier": "com.iput-object.gitswitch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gitswitch",
        "width": 960,
        "height": 600,
        "center": true,
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/iput-object/GitSwitch/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBMUYxQkVFQTA4RTZDNTkKUldSWmJJNmc3aHNmaXFIM3RWc3RESWl2YUM0b09ocVQxMHdFWFNML05jVkNvQ2pTTnZ0NFVwNGUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
